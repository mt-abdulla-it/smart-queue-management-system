# =============================================================================
# Smart Queue Management System - Environment Variables
# Copy this file to .env and update the values
# =============================================================================

# ---------- Django Core ----------
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=config.settings.development

# ---------- PostgreSQL Database ----------
DB_NAME=smart_queue_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ---------- Redis ----------
REDIS_URL=redis://127.0.0.1:6379/0

# ---------- Email (SMTP) ----------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Smart Queue <noreply@smartqueue.lk>

# ---------- JWT ----------
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ---------- SMS (Optional - Twilio) ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ---------- Site ----------
SITE_NAME=Smart Queue Management System
SITE_URL=http://localhost:8000
